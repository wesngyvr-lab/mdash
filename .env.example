# mdash configuration
# Copy to .env and fill in. .env is gitignored.

# App display name (used in dashboard headers)
APP_NAME=My App

# ─── App Store Connect ───────────────────────────────────────────────
# Create a Team API Key with "Finance" role at:
#   appstoreconnect.apple.com → Users and Access → Integrations → Team Keys
# Download the .p8 file (only shown once) and place it in ./secrets/

ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_KEY_PATH=./secrets/asc-key.p8

# Vendor number — find at:
#   appstoreconnect.apple.com → Payments and Financial Reports (top of page, 8 digits)
ASC_VENDOR_NUMBER=

# Apple App ID — numeric identifier from your app's URL or App Information page
ASC_APP_ID=

# ─── Google Play (optional, set GPLAY_ENABLED=true once Android is live) ──
GPLAY_ENABLED=false

# Service account JSON from GCP. Grant access in Play Console → Users and permissions
# (Account permissions: View app info + View financial data, both read-only)
GPLAY_SERVICE_ACCOUNT_PATH=./secrets/gplay-service-account.json

# Your app's Android package name (e.g. com.example.myapp)
GPLAY_PACKAGE_NAME=

# ─── PostHog ─────────────────────────────────────────────────────────
# Personal API key (phx_*) at: PostHog → Settings → Personal API Keys
# Scopes needed: Query: Read, Project: Read

POSTHOG_API_KEY=
POSTHOG_HOST=https://us.posthog.com

# Comma-separated list of "Display Name:Project ID" pairs.
# Project ID is numeric, shown in PostHog URL: /project/<number>
# Example: POSTHOG_PROJECTS=Mobile App:123456,Marketing Site:789012
POSTHOG_PROJECTS=

# ─── Output ──────────────────────────────────────────────────────────
# Directory where Revenue Dashboard YYYY-MM-DD.md and Friday Review YYYY-MM-DD.md
# are written. Defaults to ~/Workspace/WN Main/Dashboard if unset.
DASHBOARD_OUTPUT_DIR=
